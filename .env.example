# ============================================================
# .env.example
# Copy to .env and fill in your values.
# In Coolify paste each value into the Environment Variables form.
# NEVER commit your real .env file to GitHub.
# ============================================================

# Database (Coolify auto-fills this when you link PostgreSQL)
DATABASE_URL=postgresql://dealer_user:CHANGE_ME@postgres:5432/dealer_email
DB_PASS=CHANGE_ME

# Redis
REDIS_HOST=redis
REDIS_PASS=CHANGE_ME

# Postal SMTP (fill in after installing Postal)
POSTAL_URL=https://postal.yourdomain.com
POSTAL_API_KEY=your_postal_api_key_here

# Tracking
TRACKING_DOMAIN=app.yourdomain.com

# Opt-out / suppression service
SUPPRESSION_SERVICE_URL=https://optout.yourdomain.com
SUPPRESSION_DB_URL=postgresql://suppression_user:CHANGE_ME@postgres:5432/suppression_db
SUPPRESSION_DB_PASS=CHANGE_ME
OPT_OUT_DOMAIN=optout.yourdomain.com

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SUPPRESSION_JWT_SECRET=CHANGE_ME_generate_random_hex
PLATFORM_WEBHOOK_SECRET=CHANGE_ME_generate_random_hex
PLATFORM_WEBHOOK_URL=https://app.yourdomain.com/webhooks/unsubscribed

# Google Ads (fill in after Google API approval)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_MANAGER_ID=

# Meta / Facebook (fill in after Meta API approval)
META_SYSTEM_TOKEN=

# Asset CDN (where vehicle images and brand assets are hosted)
ASSET_CDN=https://assets.yourdomain.com

# App
NODE_ENV=production
PORT=3000
